{
    "name": "ttbooking/twig-component",
    "description": "Класс-компоненты и слоты для Twig: тег {% component %}, {% slot %}, auto-discovery реестр с манифест-кэшем. Ядро без фреймворка + опциональная Laravel-интеграция.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "twig",
        "laravel",
        "components",
        "twig-components",
        "slots",
        "twig-extension",
        "ui"
    ],
    "homepage": "https://github.com/ttbooking/twig-component",
    "support": {
        "issues": "https://github.com/ttbooking/twig-component/issues",
        "source": "https://github.com/ttbooking/twig-component"
    },
    "authors": [
        {
            "name": "TTBooking",
            "homepage": "https://github.com/ttbooking"
        }
    ],
    "require": {
        "php": "^8.3",
        "psr/container": "^1.1 || ^2.0",
        "symfony/finder": "^6.4 || ^7.0",
        "twig/twig": "^3.21"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^11.5 || ^12.0",
        "rcrowe/twigbridge": "^0.14",
        "spatie/laravel-data": "^4.0"
    },
    "suggest": {
        "laravel/framework": "Laravel-интеграция (^13): DI виджетов через контейнер, рендер через view(), artisan-команды манифеста",
        "spatie/laravel-data": "Презентационные Data-компоненты (только вместе с Laravel, ^4.0)",
        "rcrowe/twigbridge": "Мост Twig <-> Laravel views (^0.14), нужен для Laravel-интеграции"
    },
    "autoload": {
        "psr-4": {
            "TTBooking\\TwigComponent\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TTBooking\\TwigComponent\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "TTBooking\\TwigComponent\\Laravel\\TwigComponentServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    }
}
